---
# ===========================================================================
# secrets.yml — THE single file you edit when you get a new RHDP environment.
# ===========================================================================
#
# Copy this file to secrets.yml in the same directory and fill in real values:
#
#     cp secrets.yml.example secrets.yml
#
# secrets.yml is gitignored. This .example file is the only .example file in
# the repo — its whole job is to show you what secrets.yml must look like.
#
# EVERY environment-specific value lives here, not just the strictly secret
# ones. That is deliberate: re-pointing at a fresh RHDP env should mean
# editing exactly one file. connection.yml holds structure only and never
# changes between environments.
#
# Never commit real values. Never put a live RHDP hostname, cluster ID, or
# token in any tracked file, commit message, issue, or PR.
# ===========================================================================

# --- Ansible Automation Platform (from the RHDP provisioning email) --------
aap_hostname: "aap-aap.apps.cluster-<id>.dyn.redhatworkshops.io"
aap_username: "admin"
aap_password: "CHANGEME"
aap_validate_certs: false

# --- OpenShift (the "OpenShift API and Command Line Access" section) -------
openshift_api_url: "https://api.cluster-<id>.dyn.redhatworkshops.io:6443"
openshift_api_token: "sha256~CHANGEME"
openshift_validate_certs: false

# --- Automation Hub token (yours, not the environment's) ------------------
# Same token as in ~/.ansible.cfg. Used to pull Red Hat certified content.
automation_hub_token: "CHANGEME"

# --- Quay.io (private repo holding the Windows golden containerdisk) ------
# See docs/plan/ocpvirt-demo-plan.md, Phase 2. Must be a PRIVATE repo:
# a Windows image cannot be redistributed publicly.
quay_username: "CHANGEME"
quay_password: "CHANGEME"
quay_windows_image: "quay.io/<user>/windows2k22-golden:<date>"

# --- Demo VM credentials ---------------------------------------------------
# Windows: 12-72 chars, 3 of {upper, lower, digit, symbol}.
windows_admin_username: "demoadmin"
windows_admin_password: "CHANGEME-Complex-1!"
linux_admin_username: "cloud-user"
